# Copy this file to .env and fill in your values
# .env is gitignored — never commit real credentials

# ── Kaggle (for downloading PlantVillage dataset) ─────────────────────────────
# Get these from https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Hugging Face (for deploying to Spaces) ────────────────────────────────────
# Get your token from https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token

# ── Optional: experiment tracking (Weights & Biases) ─────────────────────────
# Get your key from https://wandb.ai/settings
WANDB_API_KEY=your_wandb_api_key
WANDB_PROJECT=plant-disease-detector